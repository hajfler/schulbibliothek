# ==========================================
# Schulbibliothek Dietlikon - Konfiguration
# ==========================================
# Kopiere diese Datei als .env und fülle alle Werte aus

# App
NEXTAUTH_URL=https://bibliothek.schule-dietlikon.ch
NEXTAUTH_SECRET=           # openssl rand -base64 32

# Microsoft 365 / Azure AD SSO
# Azure Portal > App-Registrierungen > Neue Registrierung
AZURE_AD_CLIENT_ID=        # Application (client) ID
AZURE_AD_CLIENT_SECRET=    # Certificates & secrets > New client secret
AZURE_AD_TENANT_ID=        # Directory (tenant) ID

# Datenbank (PostgreSQL)
DATABASE_URL=postgresql://postgres:DEIN_PASSWORT@db:5432/schulbibliothek
POSTGRES_USER=postgres
POSTGRES_PASSWORD=         # Sicheres Passwort wählen
POSTGRES_DB=schulbibliothek

# E-Mail (SMTP) für Erinnerungen
# Exchange Online / Microsoft 365 SMTP
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=bibliothek@schule-dietlikon.ch
SMTP_PASSWORD=             # E-Mail-Passwort oder App-Passwort
SMTP_FROM=bibliothek@schule-dietlikon.ch

# Cron-Sicherheitstoken für Erinnerungs-API
CRON_SECRET=               # openssl rand -base64 32

# Optional: Google Books API für ISBN-Lookup
# https://console.cloud.google.com/apis/library/books.googleapis.com
GOOGLE_BOOKS_API_KEY=

# App-Port (optional, Standard: 3000)
APP_PORT=3000
